\\\", DEFAULT_STATUS_PATH))\\n\\n\\ndef set_failed_status(error_message):\\n\\tpayload[\\\"zone_status_ok\\\"] = False\\n\\tpayload[\\\"zone_status_error\\\"] = error_message\\n\\n\\t# Safety default: if status cannot be read, stop.\\n\\tpayload[\\\"zone_state\\\"] = \\\"UNKNOWN\\\"\\n\\tpayload[\\\"machine_stop\\\"] = 1\\n\\n\\tpayload[\\\"person_total\\\"] = 0\\n\\tpayload[\\\"safe_count\\\"] = 0\\n\\tpayload[\\\"warning_count\\\"] = 0\\n\\tpayload[\\\"danger_count\\\"] = 0\\n\\tpayload[\\\"frame_id\\\"] = None\\n\\n\\tpayload[\\\"confirm_rule\\\"] = \\\"\\\"\\n\\tpayload[\\\"buffer_size\\\"] = None\\n\\tpayload[\\\"persons\\\"] = []\\n\\n\\tpayload[\\\"safe_track_ids\\\"] = []\\n\\tpayload[\\\"warning_track_ids\\\"] = []\\n\\tpayload[\\\"danger_track_ids\\\"] = []\\n\\n\\ntry:\\n\\twith status_path.open(\\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\\t\\tdata = json.load(f)\\n\\n\\tfor key in REQUIRED_KEYS:\\n\\t\\tif key not in data:\\n\\t\\t\\traise KeyError(key)\\n\\n\\tpersons = data.get(\\\"persons\\\", [])\\n\\n\\tpayload[\\\"zone_status_ok\\\"] = True\\n\\tpayload[\\\"zone_status_error\\\"] = \\\"\\\"\\n\\n\\tpayload[\\\"zone_state\\\"] = data[\\\"state\\\"]\\n\\tpayload[\\\"machine_stop\\\"] = data[\\\"machine_stop\\\"]\\n\\n\\tpayload[\\\"person_total\\\"] = data[\\\"person_total\\\"]\\n\\tpayload[\\\"safe_count\\\"] = data[\\\"safe_count\\\"]\\n\\tpayload[\\\"warning_count\\\"] = data[\\\"warning_count\\\"]\\n\\tpayload[\\\"danger_count\\\"] = data[\\\"danger_count\\\"]\\n\\tpayload[\\\"frame_id\\\"] = data[\\\"frame_id\\\"]\\n\\n\\tpayload[\\\"confirm_rule\\\"] = data.get(\\\"confirm_rule\\\", \\\"\\\")\\n\\tpayload[\\\"buffer_size\\\"] = data.get(\\\"buffer_size\\\", None)\\n\\n\\t# Full per-person detail\\n\\tpayload[\\\"persons\\\"] = persons\\n\\n\\t# Easy-to-use separated track IDs\\n\\tpayload[\\\"safe_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"SAFE\\\"\\n\\t]\\n\\n\\tpayload[\\\"warning_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"WARNING\\\"\\n\\t]\\n\\n\\tpayload[\\\"danger_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"DANGER\\\"\\n\\t]\\n\\nexcept FileNotFoundError:\\n\\tset_failed_status(\\\"status file not found\\\")\\n\\nexcept json.JSONDecodeError:\\n\\tset_failed_status(\\\"invalid json\\\")\\n\\nexcept KeyError as e:\\n\\tmissing_key = str(e).strip(\\\"'\\\")\\n\\tset_failed_status(\\\"missing required key: \\\" + missing_key)\\n\\nexcept Exception as e:\\n\\tset_failed_status(\\\"status read error: \\\" + str(e))\",\n                    \"tmp_path\": \"D:/Users/kitisak_p\",\n                    \"widget_state\": {\n                        \"editor_setting\": {\n                            \"autoComplete\": {\n                                \"caseSensitivity\": true,\n                                \"enable\": true,\n                                \"threshold\": 3\n                            },\n                            \"indent\": {\n                                \"enable\": true\n                            },\n                            \"theme\": \"Material Dark\",\n                            \"whitespace\": {\n                                \"enable\": false,\n                                \"size\": 2\n                            }\n                        },\n                        \"splt0\": 16,\n                        \"splt1\": 10\n                    }\n                },\n                \"height\": 47,\n                \"name\": \"PythonScript\",\n                \"node_enable\": true,\n                \"python_code\": \"import json\\nfrom pathlib import Path\\n\\nDEFAULT_STATUS_PATH = r\\\"D:\\\\Users\\\\kitisak_p\\\\cira_core_project\\\\detect-people-approaching-the-machine\\\\outputs\\\\zone_status.json\\\"\\n\\nREQUIRED_KEYS = [\\n\\t\\\"state\\\",\\n\\t\\\"machine_stop\\\",\\n\\t\\\"person_total\\\",\\n\\t\\\"safe_count\\\",\\n\\t\\\"warning_count\\\",\\n\\t\\\"danger_count\\\",\\n\\t\\\"frame_id\\\",\\n]\\n\\ntry:\\n\\tpayload\\nexcept NameError:\\n\\tpayload = {}\\n\\nstatus_path = Path(payload.get(\\\"zone_status_path\\\", DEFAULT_STATUS_PATH))\\n\\n\\ndef set_failed_status(error_message):\\n\\tpayload[\\\"zone_status_ok\\\"] = False\\n\\tpayload[\\\"zone_status_error\\\"] = error_message\\n\\n\\t# Safety default: if status cannot be read, stop.\\n\\tpayload[\\\"zone_state\\\"] = \\\"UNKNOWN\\\"\\n\\tpayload[\\\"machine_stop\\\"] = 1\\n\\n\\tpayload[\\\"person_total\\\"] = 0\\n\\tpayload[\\\"safe_count\\\"] = 0\\n\\tpayload[\\\"warning_count\\\"] = 0\\n\\tpayload[\\\"danger_count\\\"] = 0\\n\\tpayload[\\\"frame_id\\\"] = None\\n\\n\\tpayload[\\\"confirm_rule\\\"] = \\\"\\\"\\n\\tpayload[\\\"buffer_size\\\"] = None\\n\\tpayload[\\\"persons\\\"] = []\\n\\n\\tpayload[\\\"safe_track_ids\\\"] = []\\n\\tpayload[\\\"warning_track_ids\\\"] = []\\n\\tpayload[\\\"danger_track_ids\\\"] = []\\n\\n\\ntry:\\n\\twith status_path.open(\\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\\t\\tdata = json.load(f)\\n\\n\\tfor key in REQUIRED_KEYS:\\n\\t\\tif key not in data:\\n\\t\\t\\traise KeyError(key)\\n\\n\\tpersons = data.get(\\\"persons\\\", [])\\n\\n\\tpayload[\\\"zone_status_ok\\\"] = True\\n\\tpayload[\\\"zone_status_error\\\"] = \\\"\\\"\\n\\n\\tpayload[\\\"zone_state\\\"] = data[\\\"state\\\"]\\n\\tpayload[\\\"machine_stop\\\"] = data[\\\"machine_stop\\\"]\\n\\n\\tpayload[\\\"person_total\\\"] = data[\\\"person_total\\\"]\\n\\tpayload[\\\"safe_count\\\"] = data[\\\"safe_count\\\"]\\n\\tpayload[\\\"warning_count\\\"] = data[\\\"warning_count\\\"]\\n\\tpayload[\\\"danger_count\\\"] = data[\\\"danger_count\\\"]\\n\\tpayload[\\\"frame_id\\\"] = data[\\\"frame_id\\\"]\\n\\n\\tpayload[\\\"confirm_rule\\\"] = data.get(\\\"confirm_rule\\\", \\\"\\\")\\n\\tpayload[\\\"buffer_size\\\"] = data.get(\\\"buffer_size\\\", None)\\n\\n\\t# Full per-person detail\\n\\tpayload[\\\"persons\\\"] = persons\\n\\n\\t# Easy-to-use separated track IDs\\n\\tpayload[\\\"safe_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"SAFE\\\"\\n\\t]\\n\\n\\tpayload[\\\"warning_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"WARNING\\\"\\n\\t]\\n\\n\\tpayload[\\\"danger_track_ids\\\"] = [\\n\\t\\tp.get(\\\"track_id\\\") for p in persons\\n\\t\\tif p.get(\\\"state\\\") == \\\"DANGER\\\"\\n\\t]\\n\\nexcept FileNotFoundError:\\n\\tset_failed_status(\\\"status file not found\\\")\\n\\nexcept json.JSONDecodeError:\\n\\tset_failed_status(\\\"invalid json\\\")\\n\\nexcept KeyError as e:\\n\\tmissing_key = str(e).strip(\\\"'\\\")\\n\\tset_failed_status(\\\"missing required key: \\\" + missing_key)\\n\\nexcept Exception as e:\\n\\tset_failed_status(\\\"status read error: \\\" + str(e))\",\n                \"width\": 75\n            },\n            \"ngo\": {\n                \"comment\": {\n                    \"data\": \"\",\n                    \"show\": false\n                }\n            },\n            \"position\": {\n                \"fix\": false,\n                \"x\": -34,\n                \"y\": 136\n            }\n        },\n        {\n            \"id\": \"{77dcf96e-175e-4f22-ab5e-0de555df4da3}\",\n            \"model\": {\n                \"data\": {\n                    \"console\": \"\",\n                    \"height\": 889,\n                    \"js_code\": \"var zoneState = payload.zone_state || \\\"UNKNOWN\\\";\\nvar statusOk = payload.zone_status_ok === true;\\n\\nmux0 = false; // DANGER\\nmux1 = false; // WARNING\\nmux2 = false; // SAFE\\nmux3 = false;\\nmux4 = false;\\nmux5 = false;\\nmux6 = false;\\nmux7 = false;\\nmux8 = false;\\nmux9 = false;\\n\\nif (!statusOk) {\\n\\tmux0 = true;\\n} else if (zoneState === \\\"DANGER\\\") {\\n\\tmux0 = true;\\n} else if (zoneState === \\\"WARNING\\\") {\\n\\tmux1 = true;\\n} else if (zoneState === \\\"SAFE\\\") {\\n\\tmux2 = true;\\n} else {\\n\\tmux0 = true;\\n}\",\n                    \"widget_state\": {\n                        \"editor_setting\": {\n                            \"autoComplete\": {\n                                \"caseSensitivity\": true,\n                                \"enable\": true,\n                                \"threshold\": 3\n                            },\n                            \"indent\": {\n                                \"enable\": true\n                            },\n                            \"theme\": \"Material Dark\",\n                            \"whitespace\": {\n                                \"enable\": false,\n                                \"size\": 2\n                            }\n                        },\n                        \"splt0\": 708,\n                        \"splt1\": 177\n                    },\n                    \"width\": 1536\n                },\n                \"name\": \"Mux\",\n                \"node_enable\": true\n            },\n            \"ngo\": {\n                \"comment\": {\n                    \"data\": \"\",\n                    \"show\": false\n                }\n            },\n            \"position\": {\n                \"fix\": false,\n                \"x\": 306,\n                \"y\": 51\n            }\n        },\n        {\n            \"id\": \"{3cfab162-7f11-4c87-8821-3b5cf6b5f300}\",\n            \"model\": {\n                \"data\": {\n                    \"bold\": true,\n                    \"flow_data\": \"led_status\",\n                    \"font\": \"Ubuntu\",\n                    \"height\": 881,\n                    \"init_color\": \"#dcdcdc\",\n                    \"js_code\": \"var zoneState = payload.zone_state || \\\"UNKNOWN\\\";\\nvar statusOk = payload.zone_status_ok === true;\\n\\nif (!statusOk) {\\n\\tled = \\\"gray\\\";      // ERROR\\n} else if (zoneState === \\\"DANGER\\\") {\\n\\tled = \\\"red\\\";       // DANGER\\n} else if (zoneState === \\\"WARNING\\\") {\\n\\tled = \\\"yellow\\\";    // WARNING\\n} else if (zoneState === \\\"SAFE\\\") {\\n\\tled = \\\"green\\\";     // SAFE\\n} else {\\n\\tled = \\\"gray\\\";      // UNKNOWN / ค่าแปลก\\n}\",\n                    \"led\": \"yellow\",\n                    \"size\": 18,\n                    \"tab_index\": 1,\n                    \"text\": \"led\",\n                    \"widget_state\": {\n                        \"editor_setting\": {\n                            \"autoComplete\": {\n                                \"caseSensitivity\": true,\n                                \"enable\": true,\n                                \"threshold\": 3\n                            },\n                            \"indent\": {\n                                \"enable\": true\n                            },\n                            \"theme\": \"Material Dark\",\n                            \"whitespace\": {\n                                \"enable\": false,\n                                \"size\": 2\n                            }\n                        },\n                        \"splt0\": 518,\n                        \"splt1\": 324\n                    },\n                    \"width\": 766\n                },\n                \"height\": 191,\n                \"name\": \"LED\",\n                \"width\": 148\n            },\n            \"ngo\": {\n                \"comment\": {\n                    \"data\": \"\",\n                    \"show\": false\n                }\n            },\n            \"position\": {\n                \"fix\": false,\n                \"x\": 527,\n                \"y\": -459\n            }\n        },\n        {\n            \"id\": \"{c48510cc-fcca-4db3-9bfc-caed76330e37}\",\n            \"model\": {\n                \"data\": {\n                    \"bgColor\": \"#ffffff\",\n                    \"bold\": true,\n                    \"console\": \"\",\n                    \"flow_data\": \"led_status\",\n                    \"font\": \"Ubuntu\",\n                    \"height\": 889,\n                    \"js_code\": \"var zoneState = payload.zone_state || \\\"UNKNOWN\\\";\\nvar statusOk = payload.zone_status_ok === true;\\n\\nif (!statusOk) {\\n\\ttext = \\\"ERROR / STATUS NOT OK\\\";\\n} else if (zoneState === \\\"DANGER\\\") {\\n\\ttext = \\\"DANGER - STOP MACHINE\\\";\\n} else if (zoneState === \\\"WARNING\\\") {\\n\\ttext = \\\"WARNING - PERSON NEAR MACHINE\\\";\\n} else if (zoneState === \\\"SAFE\\\") {\\n\\ttext = \\\"SAFE - MACHINE NORMAL\\\";\\n} else {\\n\\ttext = \\\"UNKNOWN STATE - STOP MACHINE\\\";\\n}\",\n                    \"size\": 25,\n                    \"tab_index\": 0,\n                    \"textColor\": \"#000000\",\n                    \"widget_state\": {\n                        \"editor_setting\": {\n                            \"autoComplete\": {\n                                \"caseSensitivity\": true,\n                                \"enable\": true,\n                                \"threshold\": 3\n                            },\n                            \"indent\": {\n                                \"enable\": true\n                            },\n                            \"theme\": \"Material Dark\",\n                            \"whitespace\": {\n                                \"enable\": false,\n                                \"size\": 2\n                            }\n                        },\n                        \"splt0\": 684,\n                        \"splt1\": 170\n                    },\n                    \"width\": 1536\n                },\n                \"height\": 109,\n                \"name\": \"Text\",\n                \"width\": 423\n            },\n            \"ngo\": {\n                \"comment\": {\n                    \"data\": \"\",\n                    \"show\": false\n                }\n            },\n            \"position\": {\n                \"fix\": false,\n                \"x